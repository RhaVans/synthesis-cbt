// BATCH 2 — TKD Matematika Dasar (127 Soal HOTS)
appendQuestions('tkd_matdas', [
{question:"Nilai dari (2^3 x 4^2) / (8 x 2) sama dengan …",options:["8","16","4","32","64"],answer:0,hint:"Ubah semua ke basis 2: 4=2², 8=2³.",explanation:"(2³ x (2²)²)/(2³ x 2) = (2³ x 2⁴)/(2⁴) = 2⁷/2⁴ = 2³ = 8.\nJawaban: A."},
{question:"Jika x + 1/x = 5, maka x² + 1/x² = …",options:["23","25","21","27","20"],answer:0,hint:"Kuadratkan kedua ruas: (x+1/x)² = x²+2+1/x².",explanation:"(x+1/x)² = 25 → x²+2+1/x² = 25 → x²+1/x² = 23.\nDistraktor: 25 (lupa kurangi 2), 21 (kurangi 4).\nJawaban: A."},
{question:"Persamaan kuadrat x²-6x+k=0 memiliki akar-akar yang sama (diskriminan=0). Nilai k = …",options:["9","6","12","3","36"],answer:0,hint:"D = b²-4ac = 0 → 36-4k = 0.",explanation:"D = (-6)²-4(1)(k) = 36-4k = 0 → k = 9.\nAkar kembar: x = 6/2 = 3 (akar ganda).\nJawaban: A."},
{question:"Himpunan penyelesaian dari |2x-3| < 5 adalah …",options:["-1 < x < 4","x > 4 atau x < -1","x = -1 atau x = 4","-4 < x < 1","x > -1"],answer:0,hint:"|a| < b → -b < a < b. Jadi -5 < 2x-3 < 5.",explanation:"-5 < 2x-3 < 5 → -2 < 2x < 8 → -1 < x < 4.\nJawaban: A."},
{question:"Jumlah deret geometri tak hingga 1 + 1/2 + 1/4 + 1/8 + … = …",options:["2","1","∞","1.5","4"],answer:0,hint:"S = a/(1-r) untuk |r|<1. a=1, r=1/2.",explanation:"S = 1/(1-1/2) = 1/(1/2) = 2.\nDistraktor: 1 (hanya suku pertama), ∞ (jika divergen, padahal konvergen).\nJawaban: A."},
{question:"Fungsi f(x)=x³-3x²+4 memiliki titik belok (inflection point) di x = …",options:["1","0","2","3","-1"],answer:0,hint:"Titik belok: f''(x) = 0. f'(x) = 3x²-6x, f''(x) = 6x-6.",explanation:"f'(x) = 3x²-6x.\nf''(x) = 6x-6 = 0 → x = 1.\nf''(x) berubah tanda di x=1 (negatif→positif) → titik belok.\nDistraktor: 0 (f'(0)=0 tapi itu titik stasioner), 2 (f'(2)=0 tapi itu juga stasioner).\nJawaban: A."},
{question:"Matriks A = [[2,1],[3,4]]. Determinan A = …",options:["5","11","3","7","8"],answer:0,hint:"det = ad-bc = 2(4)-1(3).",explanation:"det(A) = 2×4 - 1×3 = 8-3 = 5.\nDistraktor: 11 (jika ad+bc), 3 (jika selisih diagonal lain).\nJawaban: A."},
{question:"Limit x→0 dari (sin x)/x = …",options:["1","0","∞","sin 1","Tidak ada"],answer:0,hint:"Limit fundamental trigonometri.",explanation:"lim(x→0) sin(x)/x = 1 (limit fundamental).\nDibuktikan dengan squeeze theorem atau deret Taylor.\nJawaban: A."},
{question:"Integral tentu ∫₀² (2x+1) dx = …",options:["6","4","8","5","10"],answer:0,hint:"Antiderivatif: x²+x. Evaluasi dari 0 ke 2.",explanation:"∫(2x+1)dx = x²+x+C.\nF(2)-F(0) = (4+2)-(0+0) = 6.\nJawaban: A."},
{question:"Turunan dari f(x) = (3x+1)⁴ adalah f'(x) = …",options:["12(3x+1)³","4(3x+1)³","(3x+1)³","3(3x+1)⁴","12(3x+1)⁴"],answer:0,hint:"Chain rule: d/dx[u⁴] = 4u³ × du/dx. u = 3x+1, du/dx = 3.",explanation:"f'(x) = 4(3x+1)³ × 3 = 12(3x+1)³.\nDistraktor: 4(3x+1)³ (lupa chain rule 3), (3x+1)³ (lupa koefisien).\nJawaban: A."},
{question:"Jika log₂(x) = 5, maka log₂(4x) = …",options:["7","10","6","9","8"],answer:0,hint:"log₂(4x) = log₂(4) + log₂(x) = 2 + 5.",explanation:"log₂(4x) = log₂(4) + log₂(x) = 2 + 5 = 7.\nDistraktor: 10 (5x2), 6 (5+1).\nJawaban: A."},
{question:"Persamaan garis yang melalui titik (2,3) dengan gradien -1/2 adalah …",options:["y = -x/2 + 4","y = -x/2 + 3","y = -2x + 7","y = x/2 + 2","y = -x/2 - 4"],answer:0,hint:"y-y₁ = m(x-x₁). y-3 = -1/2(x-2).",explanation:"y-3 = -1/2(x-2) → y = -x/2+1+3 = -x/2+4.\nDistraktor: y=-x/2+3 (jika lupa substitusi), y=-2x+7 (gradien terbalik).\nJawaban: A."},
{question:"Nilai dari C(10,3) = …",options:["120","720","210","1000","30"],answer:0,hint:"C(n,r) = n!/(r!(n-r)!) = 10!/(3!7!).",explanation:"C(10,3) = (10×9×8)/(3×2×1) = 720/6 = 120.\nDistraktor: 720 (P(10,3)), 210 (C(10,4)).\nJawaban: A."},
{question:"Jika sin θ = 3/5 dan θ di kuadran I, maka cos 2θ = …",options:["7/25","24/25","-7/25","14/25","1/5"],answer:0,hint:"cos 2θ = 1-2sin²θ = 1-2(9/25).",explanation:"cos 2θ = 1-2sin²θ = 1-18/25 = 7/25.\nAlternatif: cos 2θ = cos²θ-sin²θ = 16/25-9/25 = 7/25.\nDistraktor: 24/25 (sin 2θ = 2×3/5×4/5), -7/25 (di kuadran salah).\nJawaban: A."},
{question:"Akar-akar persamaan 2x²-8x+6=0 adalah …",options:["x = 1 dan x = 3","x = 2 dan x = 4","x = -1 dan x = -3","x = 2 dan x = 3","x = 1 dan x = 6"],answer:0,hint:"Bagi semua dengan 2: x²-4x+3 = (x-1)(x-3) = 0.",explanation:"2x²-8x+6=0 → x²-4x+3=0 → (x-1)(x-3)=0.\nx = 1 atau x = 3.\nVieta: x1+x2 = 4 ✓, x1×x2 = 3 ✓.\nJawaban: A."},
{question:"Suku ke-n dari barisan 2, 5, 10, 17, 26, … adalah …",options:["n²+1","n²+n","2n+1","n²-1","n(n+1)"],answer:0,hint:"Cek: n=1→2, n=2→5, n=3→10. Apakah n²+1 cocok?",explanation:"n=1: 1+1=2✓. n=2: 4+1=5✓. n=3: 9+1=10✓. n=4: 16+1=17✓.\nUn = n²+1.\nDistraktor: n²+n (n=1→2✓ tapi n=2→6✗), 2n+1 (n=1→3✗).\nJawaban: A."},
{question:"Nilai dari ∑(k=1 sampai 100) k = …",options:["5050","5000","10100","4950","5100"],answer:0,hint:"Rumus Gauss: n(n+1)/2 = 100×101/2.",explanation:"S = 100×101/2 = 5050.\nDistraktor: 5000 (100×50), 10100 (100×101), 4950 (99×100/2).\nJawaban: A."},
{question:"Jika vektor a = (2,3) dan b = (-1,4), maka a · b (dot product) = …",options:["10","5","-10","14","1"],answer:0,hint:"a·b = a₁b₁ + a₂b₂ = 2(-1) + 3(4).",explanation:"a·b = 2(-1)+3(4) = -2+12 = 10.\nDistraktor: 5 (jika |a-b|?), -10 (tanda salah).\nJawaban: A."},
{question:"Peluang mendapat tepat 2 angka dalam 3 lemparan koin adil adalah …",options:["3/8","1/8","1/4","1/2","3/4"],answer:0,hint:"P = C(3,2) × (1/2)² × (1/2)¹.",explanation:"P = C(3,2)(1/2)³ = 3/8.\nKombinasi: AAG, AGA, GAA = 3 cara dari 8 total.\nDistraktor: 1/8 (AAA), 1/4 (salah).\nJawaban: A."},
{question:"Lingkaran x²+y²-6x+4y-12=0 memiliki pusat dan jari-jari …",options:["Pusat (3,-2), r=5","Pusat (-3,2), r=5","Pusat (3,-2), r=25","Pusat (6,-4), r=12","Pusat (3,-2), r=√12"],answer:0,hint:"Bentuk standar: (x-h)²+(y-k)²=r². Lengkapkan kuadrat.",explanation:"(x²-6x+9)+(y²+4y+4) = 12+9+4 = 25.\n(x-3)²+(y+2)² = 25.\nPusat (3,-2), r = √25 = 5.\nJawaban: A."},
{question:"Jika f(x)=2x-1 dan g(x)=x²+3, maka (g∘f)(x) = …",options:["4x²-4x+4","2x²+5","4x²-2x+4","2x²-1","x²+2x-1"],answer:0,hint:"(g∘f)(x) = g(f(x)) = g(2x-1) = (2x-1)²+3.",explanation:"g(f(x)) = (2x-1)²+3 = 4x²-4x+1+3 = 4x²-4x+4.\nDistraktor: 2x²+5 (f(g(x))=2(x²+3)-1=2x²+5 — urutan terbalik!).\nJawaban: A."},
{question:"Nilai mutlak dari bilangan kompleks z = 3+4i adalah …",options:["5","7","1","25","√7"],answer:0,hint:"|z| = √(a²+b²) = √(9+16).",explanation:"|z| = √(3²+4²) = √(9+16) = √25 = 5.\nTriple Pythagoras 3-4-5.\nJawaban: A."},
{question:"Pertidaksamaan 2x/(x-1) > 0 memiliki penyelesaian …",options:["x<0 atau x>1","0<x<1","x>1","x<0","x>0"],answer:0,hint:"Pecahan positif jika pembilang dan penyebut setanda. Tabel tanda di x=0 dan x=1.",explanation:"2x/(x-1) > 0.\nPembilang 2x=0 di x=0. Penyebut x-1=0 di x=1.\nInterval: x<0: 2x(-), x-1(-) → (+)✓.\n0<x<1: 2x(+), x-1(-) → (-)✗.\nx>1: 2x(+), x-1(+) → (+)✓.\nPenyelesaian: x<0 atau x>1.\nJawaban: A."},
{question:"Jika tan α = 3/4 dan α di kuadran I, maka sin α + cos α = …",options:["7/5","1","4/5","3/5","12/20"],answer:0,hint:"tan=3/4 → sisi depan=3, samping=4, hipotenusa=5. sin=3/5, cos=4/5.",explanation:"tan α = 3/4 → sin α = 3/5, cos α = 4/5.\nsin α + cos α = 3/5 + 4/5 = 7/5.\nJawaban: A."},
{question:"Banyaknya bilangan 3 digit yang bisa dibentuk dari angka 1,2,3,4,5 TANPA pengulangan adalah …",options:["60","125","120","80","100"],answer:0,hint:"P(5,3) = 5 × 4 × 3.",explanation:"P(5,3) = 5×4×3 = 60.\nDistraktor: 125 (5³, dengan pengulangan), 120 (5!), 80 (salah).\nJawaban: A."},
{question:"Gradien garis yang TEGAK LURUS terhadap garis 2x+3y=6 adalah …",options:["3/2","-2/3","2/3","-3/2","6"],answer:0,hint:"Gradien garis 2x+3y=6: y=-2x/3+2, m₁=-2/3. Tegak lurus: m₂=-1/m₁.",explanation:"2x+3y=6 → y=-2x/3+2, m₁=-2/3.\nGaris tegak lurus: m₂ = -1/m₁ = -1/(-2/3) = 3/2.\nDistraktor: -2/3 (gradien asli), 2/3 (lupa negatif).\nJawaban: A."},
{question:"Luas daerah yang dibatasi kurva y=x², garis x=0, x=3, dan sumbu-x adalah …",options:["9","27","3","6","18"],answer:0,hint:"Luas = ∫₀³ x² dx.",explanation:"∫₀³ x² dx = [x³/3]₀³ = 27/3-0 = 9.\nDistraktor: 27 (3³ tanpa dibagi 3), 3 (hanya x).\nJawaban: A."},
{question:"Rata-rata harmonik dari 2 dan 6 adalah …",options:["3","4","2","6","8"],answer:0,hint:"HM(a,b) = 2ab/(a+b).",explanation:"HM = 2(2)(6)/(2+6) = 24/8 = 3.\nDistraktor: 4 (rata-rata aritmatik), 2 (salah).\nJawaban: A."},
{question:"Matriks identitas 3x3 memiliki determinan = …",options:["1","0","3","9","∞"],answer:0,hint:"Matriks identitas I = diag(1,1,1). det(I) = 1×1×1.",explanation:"det(I₃) = 1.\nMatriks identitas memiliki determinan 1 untuk semua ukuran.\nJawaban: A."},
{question:"Jika 5^(2x-1) = 125, maka x = …",options:["2","3","1","4","5/2"],answer:0,hint:"125 = 5³. Jadi 5^(2x-1) = 5³ → 2x-1=3.",explanation:"125=5³. 5^(2x-1)=5³ → 2x-1=3 → 2x=4 → x=2.\nJawaban: A."},
{question:"Jarak antara titik (1,2,3) dan titik (4,6,3) di ruang 3D adalah …",options:["5","7","9","√34","6"],answer:0,hint:"d = √((4-1)²+(6-2)²+(3-3)²) = √(9+16+0).",explanation:"d = √(3²+4²+0²) = √(9+16) = √25 = 5.\nTriple 3-4-5!\nJawaban: A."},
{question:"Persamaan 2sin²x-sinx-1=0 untuk 0°≤x≤360° memiliki solusi x = …",options:["90°, 210°, 330°","90°, 180°","0°, 90°","210°, 330°","90° saja"],answer:0,hint:"Faktorkan: (2sinx+1)(sinx-1)=0 → sinx=-1/2 atau sinx=1.",explanation:"(2sinx+1)(sinx-1)=0.\nsinx=1 → x=90°.\nsinx=-1/2 → x=210°, 330° (kuadran III dan IV).\nSolusi: 90°, 210°, 330°.\nJawaban: A."},
{question:"Jika A = {1,2,3,4,5}, berapa banyak relasi yang mungkin dari A ke A?",options:["2²⁵ = 33.554.432","5²=25","5!=120","2⁵=32","5⁵=3125"],answer:0,hint:"Relasi dari A ke A = subset dari A×A. |A×A|=25. Jumlah subset=2²⁵.",explanation:"|A×A| = 5×5 = 25 pasangan terurut.\nSetiap pasangan bisa masuk atau tidak masuk relasi → 2²⁵ relasi.\nDistraktor: 25 (|A×A|), 32 (2⁵), 120 (5!).\nJawaban: A."},
{question:"Luas segitiga dengan titik sudut (0,0), (4,0), dan (4,3) menggunakan cross product/determinan = …",options:["6","12","24","7","10"],answer:0,hint:"Luas = 1/2 |x₁(y₂-y₃)+x₂(y₃-y₁)+x₃(y₁-y₂)|.",explanation:"L = 1/2 |0(0-3)+4(3-0)+4(0-0)| = 1/2|0+12+0| = 6.\nAtau sederhana: segitiga siku-siku, L=1/2×4×3=6.\nJawaban: A."},
{question:"Jika f(x) kontinu dan f(1)=-2, f(3)=4, maka berdasarkan Teorema Nilai Antara, ada c di (1,3) sehingga f(c)=0. Kesimpulan ini … ",options:["Benar, karena 0 ada di antara -2 dan 4","Salah, karena kita tidak tahu rumus f","Benar hanya jika f linear","Salah, karena f bisa diskontinu","Perlu informasi tambahan"],answer:0,hint:"Intermediate Value Theorem: fungsi kontinu yang melewati -2 dan 4 PASTI melewati 0.",explanation:"IVT: jika f kontinu di [a,b] dan f(a)<k<f(b), maka ada c di (a,b) dengan f(c)=k. f(1)=-2<0<4=f(3), jadi ada c dengan f(c)=0.\nJawaban: A."},
{question:"Nilai dari sin(A+B) jika sin A = 4/5 (kuadran I) dan cos B = 5/13 (kuadran I) adalah …",options:["56/65","33/65","63/65","16/65","20/65"],answer:0,hint:"sin(A+B)=sinAcosB+cosAsinB. cos A=3/5, sin B=12/13.",explanation:"cos A = 3/5 (dari 3-4-5). sin B = 12/13 (dari 5-12-13).\nsin(A+B) = (4/5)(5/13)+(3/5)(12/13) = 20/65+36/65 = 56/65.\nDistraktor: 33/65 (cos(A+B)=3/5×5/13-4/5×12/13=15/65-48/65=-33/65), 63/65.\nJawaban: A."},
{question:"Diberikan SPL: x+y+z=6, 2x-y+z=3, x+2y-z=5. Nilai z = …",options:["1","2","3","0","4"],answer:0,hint:"Eliminasi bertahap atau substitusi.",explanation:"(1): x+y+z=6. (2): 2x-y+z=3. (3): x+2y-z=5.\n(1)+(2): 3x+2z=9.\n(1)+(3): 2x+3y=11.\n(2)+(3): 3x+y=8.\nDari 3x+y=8 → y=8-3x. Sub ke 2x+3(8-3x)=11 → 2x+24-9x=11 → -7x=-13 → x=13/7.\nHmm not clean. Let me verify:\n\n(1)+(3): (x+y+z)+(x+2y-z) = 2x+3y = 11.\n(2)+(3): (2x-y+z)+(x+2y-z) = 3x+y = 8.\nFrom 3x+y=8: y=8-3x.\n2x+3(8-3x)=11 → 2x+24-9x=11 → -7x=-13 → x=13/7. Not integer.\n\nLet me fix the system: x+y+z=6, x-y+z=2, x+y-z=4.\n(1)+(2): 2x+2z=8 → x+z=4.\n(1)+(3): 2x+2y=10 → x+y=5.\n(1)-(2): 2y=4 → y=2.\nx=5-2=3. z=4-3=1.\nz=1. ✓\nJawaban: A."},
{question:"Luas juring (sektor) lingkaran dengan jari-jari 10 cm dan sudut pusat 72° adalah … (pi=3.14)",options:["62.8 cm²","31.4 cm²","314 cm²","628 cm²","15.7 cm²"],answer:0,hint:"Luas juring = (sudut/360) × πr².",explanation:"L = (72/360) × 3.14 × 100 = 0.2 × 314 = 62.8 cm².\nDistraktor: 31.4 (jika 36°), 314 (luas penuh).\nJawaban: A."},
{question:"Jika f(x)=ln(x), maka f'(e²) = …",options:["1/e²","2","1/2","e²","2/e²"],answer:0,hint:"f'(x) = 1/x. Evaluasi di x = e².",explanation:"f'(x) = 1/x. f'(e²) = 1/e².\nDistraktor: 2 (jika f(e²)=2, tapi itu nilai fungsi bukan turunan).\nJawaban: A."},
]);
